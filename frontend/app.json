{
  "expo": {
    "name": "Emmas-Envy",
    "slug": "Emmas-Envy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/emmasenvy.png",
    "scheme": "emmasenvy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emmasenvy.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Bluetooth is used to pair your Square card reader for in-person payments.",
        "NSBluetoothPeripheralUsageDescription": "Bluetooth is used to pair your Square card reader.",
        "NSLocationWhenInUseUsageDescription": "Location may be required on some devices to discover nearby Bluetooth card readers."
      }
    },
    "android": {
      "package": "com.emmasenvy.app",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0d0d0d",
        "foregroundImage": "./assets/images/emmasenvy.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/emmasenvy.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#e91e8c",
          "dark": {
            "backgroundColor": "#0d0d0d"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to your photos to attach inspiration images to appointments.",
          "cameraPermission": "Allow the camera to take after-visit photos when completing a service."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
